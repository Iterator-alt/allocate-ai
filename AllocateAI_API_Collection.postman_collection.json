{
	"info": {
		"_postman_id": "allocate-ai-collection-v1",
		"name": "AllocateAI API",
		"description": "Allocate.AI Media Budget Allocation API\n\nFlow (Manager's Spec v2 - JS Backend creates run):\n1. POST /runs/start → starts existing run (created by JS Backend)\n2. Poll GET /status until \"awaiting_confirmation\"\n3. GET /competitors → review competitor list\n4. POST /runs/competitors/confirm → triggers Stage 2-4 (run_id in body)\n5. Poll GET /status until \"completed\"\n6. GET /result → allocation results\n7. GET /chat → feedback cards\n8. GET /trace → prompt traces (Owner only)\n\nAlternative Flow (AI Backend creates run):\n1. POST /runs → creates AND starts run\n2-8. Same as above",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://127.0.0.1:8081/health",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["health"]
						},
						"description": "Check if the API is healthy"
					},
					"response": []
				}
			]
		},
		{
			"name": "1. Start/Create Run",
			"item": [
				{
					"name": "POST /runs/start - Start Existing Run (v2)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"run_id\": 1,\n    \"action\": \"start\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/start",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "start"]
						},
						"description": "Start an existing run (Manager's Spec v2).\n\nThe run must already exist in DB (created by JS Backend).\nThis endpoint triggers Stage 1 (competitor matching) in background.\n\nAfter this, poll GET /status until status = \"awaiting_confirmation\""
					},
					"response": []
				},
				{
					"name": "POST /runs - Create Run (Knorr)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customer_name\": \"Knorr\",\n    \"industry\": \"Food\",\n    \"brand_kpi\": \"adaware\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs"]
						},
						"description": "Create a new run. Auto-triggers Stage 1 (competitor matching) in background.\n\nAfter this, poll GET /status until status = \"awaiting_confirmation\""
					},
					"response": []
				},
				{
					"name": "POST /runs - Create Run (Maggi)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customer_name\": \"Maggi\",\n    \"industry\": \"Food\",\n    \"brand_kpi\": \"consider\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs"]
						},
						"description": "Create a run for Maggi brand with 'consider' KPI"
					},
					"response": []
				},
				{
					"name": "POST /runs - Create Run (Full Options)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customer_name\": \"Heinz\",\n    \"industry\": \"Food\",\n    \"brand_kpi\": \"adaware\",\n    \"total_budget\": 500000,\n    \"time_period_start\": \"2025-01-01T00:00:00Z\",\n    \"time_period_end\": \"2025-12-31T23:59:59Z\",\n    \"channels\": [\"TV\", \"Digital\", \"Radio\", \"OOH\"],\n    \"goal_text\": \"Increase brand awareness in Germany\",\n    \"direction\": \"increase\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs"]
						},
						"description": "Create a run with all optional parameters filled"
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Poll Status",
			"item": [
				{
					"name": "GET /runs/{id}/status - Poll Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/status",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "status"]
						},
						"description": "Poll run status until completed.\n\nChange the run ID in the URL (replace 1 with your run_id)\n\nStatus progression:\n- pending → matching (S1) → awaiting_confirmation (S1.5)\n- [after confirm] → generating (S2) → parsing (S3) → feedback (S4) → completed"
					},
					"response": []
				},
				{
					"name": "GET /runs/{id} - Get Full Run Details",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1"]
						},
						"description": "Get full details of a run including all input parameters"
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Get Competitors",
			"item": [
				{
					"name": "GET /runs/{id}/competitors - Get Competitors",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/competitors",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "competitors"]
						},
						"description": "Get matched competitors for a run.\n\nAvailable once status = \"awaiting_confirmation\"\n\nResponse includes:\n- competitors list with brand names and KPI data\n- brand_info with target brand's KPI scores and spend\n- warnings if data is limited"
					},
					"response": []
				}
			]
		},
		{
			"name": "4. Confirm Competitors",
			"item": [
				{
					"name": "POST /runs/competitors/confirm - Approve (v2)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"run_id\": 1,\n    \"action\": \"approved\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/competitors/confirm",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "competitors", "confirm"]
						},
						"description": "Approve competitors using Manager's Spec v2 (run_id in body).\n\nAccepts both 'approve' and 'approved' action values.\nUses all competitors from Stage 1 (no selected_competitors param).\n\nAfter this, poll GET /status until status = \"completed\""
					},
					"response": []
				},
				{
					"name": "POST /runs/competitors/confirm - Cancel (v2)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"run_id\": 1,\n    \"action\": \"cancel\",\n    \"reason\": \"Competitors not suitable for this campaign\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/competitors/confirm",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "competitors", "confirm"]
						},
						"description": "Cancel the run using Manager's Spec v2 (run_id in body)"
					},
					"response": []
				},
				{
					"name": "POST /competitors/confirm - Approve All",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"approve\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/competitors/confirm",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "competitors", "confirm"]
						},
						"description": "Approve all competitors and auto-start AI generation (Stage 2-4).\n\nAfter this, poll GET /status until status = \"completed\""
					},
					"response": []
				},
				{
					"name": "POST /competitors/confirm - Approve Selected",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"approve\",\n    \"selected_competitors\": [\n        \"Maggi\",\n        \"Heinz\",\n        \"Nestlé\"\n    ]\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/competitors/confirm",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "competitors", "confirm"]
						},
						"description": "Approve only selected competitors (filter the list)"
					},
					"response": []
				},
				{
					"name": "POST /competitors/confirm - Cancel",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"cancel\",\n    \"reason\": \"Competitors not suitable for this campaign\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/competitors/confirm",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "competitors", "confirm"]
						},
						"description": "Cancel the run - reject competitors"
					},
					"response": []
				}
			]
		},
		{
			"name": "5. Get Result",
			"item": [
				{
					"name": "GET /runs/{id}/result - Get Allocation",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/result",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "result"]
						},
						"description": "Get allocation results.\n\nAvailable once status = \"completed\"\n\nResponse includes:\n- allocations with channel, share_pct, budget, reasoning\n- reasoning_summary\n- confidence_score\n- warnings"
					},
					"response": []
				}
			]
		},
		{
			"name": "6. Get Chat",
			"item": [
				{
					"name": "GET /runs/{id}/chat - Get Feedback Cards",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/chat",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "chat"]
						},
						"description": "Get feedback cards / chat history.\n\nAvailable once status = \"completed\"\n\nResponse includes:\n- messages with type (summary, warning, recommendation)\n- severity (info, warning, error)\n- has_warnings, has_alerts flags"
					},
					"response": []
				}
			]
		},
		{
			"name": "7. Get Trace (Owner Only)",
			"item": [
				{
					"name": "GET /runs/{id}/trace - Get Prompt Trace",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							},
							{
								"key": "X-User-Role",
								"value": "owner"
							}
						],
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/trace",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "trace"]
						},
						"description": "Get prompt traces for debugging.\n\nOwner access required - set X-User-Role: owner header.\n\nResponse includes:\n- Full prompt sent to LLM\n- LLM response\n- Token usage\n- Latency"
					},
					"response": []
				}
			]
		},
		{
			"name": "8. Stop Run",
			"item": [
				{
					"name": "POST /runs/{id}/stop - Stop Run",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reason\": \"User cancelled the run\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/runs/1/stop",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "runs", "1", "stop"]
						},
						"description": "Stop/cancel a run in progress.\n\nCannot stop runs that are already completed, failed, or cancelled."
					},
					"response": []
				}
			]
		},
		{
			"name": "Stage 1 Direct (Debug)",
			"item": [
				{
					"name": "POST /stage1/process - Direct Stage 1",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Token",
								"value": "test-session-123"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"brand_name\": \"Knorr\",\n    \"industry\": \"Food\",\n    \"brand_kpi\": \"adaware\",\n    \"media_channels\": [\"TV\", \"Digital\"],\n    \"goal_direction\": \"budget_to_impact\"\n}"
						},
						"url": {
							"raw": "http://127.0.0.1:8081/api/v1/stage1/process",
							"protocol": "http",
							"host": ["127", "0", "0", "1"],
							"port": "8081",
							"path": ["api", "v1", "stage1", "process"]
						},
						"description": "Direct Stage 1 processing (for debugging).\n\nNormally you don't need this - Stage 1 runs automatically after POST /runs"
					},
					"response": []
				}
			]
		}
	]
}
