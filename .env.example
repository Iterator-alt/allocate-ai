# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/allocate_ai

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_GENERATIONS_PER_HOUR=20

# LLM Settings
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=3

# Cache
RESULT_CACHE_TTL_SECONDS=3600
